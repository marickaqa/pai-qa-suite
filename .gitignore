# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Reports — deny everything, always.
# Sessions, tokens, screenshots, eval output all live here and none of it
# belongs in git. Deny-all means a new debug artifact can never leak again.
reports/*
!reports/.gitkeep

# Playwright output
test-results/
playwright-report/
blob-report/

# TypeScript
dist/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
